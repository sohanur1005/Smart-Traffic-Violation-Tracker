<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0" 
      style="-fx-background-color: #0b1a30;" 
      stylesheets="@style.css" 
      xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="50.0" right="50.0" top="30.0"/>
    </padding>

    <Label text="TRAFFIC VIOLATION TRACKER" style="-fx-text-fill: #e8a87c; -fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label text="Law Enforcement Administration Panel" style="-fx-text-fill: #b8c7db; -fx-font-size: 14px;"/>

    <VBox spacing="10.0" maxWidth="320.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8px;">
        <Label text="Sign In" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <Label text="Username" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        <TextField fx:id="usernameField" promptText="Enter username"/>
        
        <Label text="Password" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"/>
        
        <Button fx:id="loginButton" text="Login" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity" style="-fx-margin-top: 10;"/>
        
        <Hyperlink text="Don't have an account? Register here" onAction="#goToRegister" style="-fx-text-fill: #3182ce; -fx-font-size: 12px; -fx-alignment: center; -fx-padding: 5 0 0 0;"/>
        
        <Label fx:id="errorLabel" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;" visible="false" wrapText="true"/>
    </VBox>
</VBox>
