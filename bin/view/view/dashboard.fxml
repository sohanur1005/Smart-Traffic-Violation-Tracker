<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1050.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
    <!-- Sidebar Left -->
    <left>
        <VBox prefWidth="240.0" styleClass="sidebar" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="5.0" alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #1e3a60 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 10;">
                    <Label text="TRAFFIC TRACKER" styleClass="sidebar-title"/>
                    <Label fx:id="userNameLabel" text="Officer: Name" style="-fx-text-fill: #b8c7db; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label fx:id="userRoleLabel" text="Role: OFFICER" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                </VBox>
                
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnHome" text="Dashboard Home" onAction="#showHomeView" styleClass="nav-button" prefWidth="220.0" />
                        <Button fx:id="btnDrivers" text="Manage Drivers" onAction="#showDriversView" styleClass="nav-button" prefWidth="220.0"/>
                        <Button fx:id="btnVehicles" text="Manage Vehicles" onAction="#showVehiclesView" styleClass="nav-button" prefWidth="220.0"/>
                        <Button fx:id="btnViolations" text="Manage Violations" onAction="#showViolationsView" styleClass="nav-button" prefWidth="220.0"/>
                        <Button fx:id="btnRecords" text="Issue Traffic Ticket" onAction="#showRecordsView" styleClass="nav-button" prefWidth="220.0"/>
                    </children>
                </VBox>
                
                <Button text="Sign Out" onAction="#handleLogout" styleClass="btn-danger" prefWidth="220.0"/>
            </children>
        </VBox>
    </left>
    
    <!-- Central Content Area -->
    <center>
        <VBox style="-fx-background-color: #f4f6f9;" BorderPane.alignment="CENTER">
            <!-- Header Top Bar -->
            <children>
                <HBox styleClass="header-bar" alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="headerTitle" text="Dashboard Home" styleClass="header-title"/>
                    </children>
                </HBox>
                
                <!-- Dynamic Section Container -->
                <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">
                    <!-- Default Dashboard Home view components -->
                    <children>
                        <VBox fx:id="homeViewPane" spacing="20.0">
                            <children>
                                <!-- Stats Row -->
                                <HBox spacing="20.0" alignment="CENTER">
                                    <children>
                                        <!-- Card 1 -->
                                        <VBox styleClass="stats-card" HBox.hgrow="ALWAYS" prefWidth="200.0">
                                            <children>
                                                <Label text="TOTAL DRIVERS" styleClass="stats-card-title"/>
                                                <Label fx:id="statDriversCount" text="0" styleClass="stats-card-value"/>
                                            </children>
                                        </VBox>
                                        <!-- Card 2 -->
                                        <VBox styleClass="stats-card" HBox.hgrow="ALWAYS" prefWidth="200.0">
                                            <children>
                                                <Label text="TOTAL VEHICLES" styleClass="stats-card-title"/>
                                                <Label fx:id="statVehiclesCount" text="0" styleClass="stats-card-value"/>
                                            </children>
                                        </VBox>
                                        <!-- Card 3 -->
                                        <VBox styleClass="stats-card" HBox.hgrow="ALWAYS" prefWidth="200.0">
                                            <children>
                                                <Label text="TOTAL TICKETS" styleClass="stats-card-title"/>
                                                <Label fx:id="statTicketsCount" text="0" styleClass="stats-card-value"/>
                                            </children>
                                        </VBox>
                                        <!-- Card 4 -->
                                        <VBox styleClass="stats-card" HBox.hgrow="ALWAYS" prefWidth="200.0">
                                            <children>
                                                <Label text="TOTAL UNPAID FINES" styleClass="stats-card-title"/>
                                                <Label fx:id="statFinesUnpaid" text="$0.00" styleClass="stats-card-value" style="-fx-text-fill: #e53e3e;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                
                                <!-- Recent Violations Table Section -->
                                <VBox spacing="10.0" VBox.vgrow="ALWAYS" styleClass="form-container">
                                    <children>
                                        <Label text="Recent Violations Log" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                        <TableView fx:id="recentViolationsTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="80.0" text="Ticket ID" />
                                                <TableColumn fx:id="colDriver" prefWidth="180.0" text="Driver" />
                                                <TableColumn fx:id="colPlate" prefWidth="120.0" text="Plate Number" />
                                                <TableColumn fx:id="colCode" prefWidth="120.0" text="Violation Code" />
                                                <TableColumn fx:id="colFine" prefWidth="100.0" text="Fine Levied" />
                                                <TableColumn fx:id="colDate" prefWidth="140.0" text="Date" />
                                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </center>
</BorderPane>
