<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ViolationController">
    <!-- Left Panel: Table of Violations -->
    <children>
        <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="form-container">
            <children>
                <TableView fx:id="violationTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colCode" prefWidth="150.0" text="Violation Code" />
                        <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
                        <TableColumn fx:id="colFine" prefWidth="120.0" text="Fine Amount" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        
        <!-- Right Panel: Form -->
        <VBox prefWidth="300.0" spacing="12.0" styleClass="form-container">
            <children>
                <Label text="Violation Type Profile" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <Label text="Violation Code *" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="codeField" promptText="e.g. SPEED_LIMIT"/>
                
                <Label text="Description *" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextArea fx:id="descField" prefHeight="80.0" promptText="e.g. Exceeding speed limits..." wrapText="true"/>
                
                <Label text="Base Fine Amount ($) *" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="fineField" promptText="e.g. 150.00"/>
                
                <Label text="* Mandatory fields" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
                
                <!-- Buttons Row -->
                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button fx:id="btnAdd" text="Add" onAction="#handleAddViolation" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdateViolation" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteViolation" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="btnClear" text="Clear" onAction="#clearForm" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </children>
                </HBox>
                
                <Label fx:id="statusLabel" text="Status" visible="false" wrapText="true" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
            </children>
        </VBox>
    </children>
</HBox>
