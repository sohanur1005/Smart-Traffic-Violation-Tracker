<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.VehicleController">
    <!-- Left Panel: Table of Vehicles -->
    <children>
        <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="form-container">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Search Vehicle Plate:" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="searchField" promptText="Enter plate number..." HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"/>
                    </children>
                </HBox>
                
                <TableView fx:id="vehicleTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colPlate" prefWidth="130.0" text="Plate No" />
                        <TableColumn fx:id="colOwner" prefWidth="200.0" text="Owner Name" />
                        <TableColumn fx:id="colModel" prefWidth="130.0" text="Model" />
                        <TableColumn fx:id="colColor" prefWidth="110.0" text="Color" />
                        <TableColumn fx:id="colType" prefWidth="110.0" text="Type" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        
        <!-- Right Panel: CRUD Operations Form -->
        <VBox prefWidth="320.0" spacing="12.0" styleClass="form-container">
            <children>
                <Label text="Vehicle Registration Profile" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <Label text="Plate Number *" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="plateField" promptText="e.g. ABC-1234"/>
                
                <Label text="Owner Driver *" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <ComboBox fx:id="ownerComboBox" promptText="Select owner driver" maxWidth="Infinity"/>
                
                <Label text="Model" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="modelField" promptText="e.g. Tesla Model 3"/>
                
                <Label text="Color" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="colorField" promptText="e.g. Red"/>
                
                <Label text="Vehicle Type" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <ComboBox fx:id="typeComboBox" promptText="Select type" maxWidth="Infinity"/>
                
                <Label text="* Mandatory fields" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
                
                <!-- Buttons Row -->
                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button fx:id="btnAdd" text="Add" onAction="#handleAddVehicle" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdateVehicle" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteVehicle" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="btnClear" text="Clear" onAction="#clearForm" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </children>
                </HBox>
                
                <Label fx:id="statusLabel" text="Status" visible="false" wrapText="true" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
            </children>
        </VBox>
    </children>
</HBox>
