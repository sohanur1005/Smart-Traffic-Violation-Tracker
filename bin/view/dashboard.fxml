                                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                                        <children>
                                                            <Label text="Address:" style="-fx-font-size: 12px; -fx-text-fill: #718096; -fx-min-width: 120;"/>
                                                            <Label fx:id="profileAddress" text="—" style="-fx-font-size: 13px; -fx-text-fill: #2d3748;" wrapText="true"/>
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>

                                            <!-- Fine Summary Card -->
                                            <VBox spacing="14" prefWidth="290" styleClass="form-container">
                                                <children>
                                                    <Label text="💰 Fine Summary" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                                    <Separator/>

                                                    <VBox spacing="10">
                                                        <children>
                                                            <HBox alignment="CENTER_LEFT" spacing="10"
                                                                  style="-fx-background-color: #fff5f5; -fx-padding: 10 12; -fx-background-radius: 6;">
