                                                    </HBox>
                                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                                        <children>
                                                            <Label text="Account Role:" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                                                            <Label fx:id="profileRole" text="USER" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #38a169;"/>
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                        </children>
                    </StackPane>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
