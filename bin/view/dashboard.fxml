                                                    </HBox>
                                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                                        <children>
                                                            <Label text="Phone Number:" style="-fx-font-size: 12px; -fx-text-fill: #718096; -fx-min-width: 120;"/>
