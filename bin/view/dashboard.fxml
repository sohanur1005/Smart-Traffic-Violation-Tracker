                                                        <children>
                                                            <Label text="Username:" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                                                            <Label fx:id="profileUsername" text="—" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
