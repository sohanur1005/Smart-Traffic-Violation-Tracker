                                                                    <Label text="💸 Total Fines Owed:" style="-fx-font-size: 12px; -fx-text-fill: #742a2a;"/>
                                                                    <HBox HBox.hgrow="ALWAYS"/>
                                                                    <Label fx:id="profileTotalOwed" text="\$0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e53e3e;"/>
                                                                </children>
                                                            </HBox>
                                                            <HBox alignment="CENTER_LEFT" spacing="10"
                                                                  style="-fx-background-color: #f0fff4; -fx-padding: 10 12; -fx-background-radius: 6;">
                                                                <children>
                                                                    <Label text="✅ Total Paid:" style="-fx-font-size: 12px; -fx-text-fill: #22543d;"/>
                                                                    <HBox HBox.hgrow="ALWAYS"/>
                                                                    <Label fx:id="profileTotalPaid" text="\$0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #38a169;"/>
                                                                </children>
                                                            </HBox>
                                                            <HBox alignment="CENTER_LEFT" spacing="10"
                                                                  style="-fx-background-color: #fffaf0; -fx-padding: 10 12; -fx-background-radius: 6;">
                                                                <children>
                                                                    <Label text="⏳ Pending Approval:" style="-fx-font-size: 12px; -fx-text-fill: #744210;"/>
                                                                    <HBox HBox.hgrow="ALWAYS"/>
                                                                    <Label fx:id="profileTotalPending" text="\$0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #dd6b20;"/>
                                                                </children>
                                                            </HBox>
                                                            <HBox alignment="CENTER_LEFT" spacing="10"
                                                                  style="-fx-background-color: #ebf8ff; -fx-padding: 10 12; -fx-background-radius: 6;">
                                                                <children>
                                                                    <Label text="🎫 Total Tickets:" style="-fx-font-size: 12px; -fx-text-fill: #2b6cb0;"/>
                                                                    <HBox HBox.hgrow="ALWAYS"/>
                                                                    <Label fx:id="profileTotalTickets" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3182ce;"/>
                                                                </children>
                                                            </HBox>
                                                        </children>
                                                    </VBox>

                                                    <Button text="📋  View My Citations" onAction="#showMyCitationsView"
                                                            style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 4px; -fx-cursor: hand; -fx-max-width: Infinity;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- Account Info Card -->
                                    <VBox spacing="14" styleClass="form-container">
                                        <children>
                                            <Label text="🔐 Account Information" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
